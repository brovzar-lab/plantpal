rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /profile/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /plants/{plantId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /growthEntries/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        match /careLog/{logId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      match /careTasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
